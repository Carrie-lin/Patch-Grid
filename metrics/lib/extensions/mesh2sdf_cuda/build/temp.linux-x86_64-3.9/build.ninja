ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -B /ghome/l3/gylin/anaconda3/envs/patchgrid/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /ghome/l3/gylin/anaconda3/envs/patchgrid/include -fPIC -O2 -isystem /ghome/l3/gylin/anaconda3/envs/patchgrid/include -fPIC -I/ghome/l3/gylin/anaconda3/envs/patchgrid/lib/python3.9/site-packages/torch/include -I/ghome/l3/gylin/anaconda3/envs/patchgrid/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/ghome/l3/gylin/anaconda3/envs/patchgrid/lib/python3.9/site-packages/torch/include/TH -I/ghome/l3/gylin/anaconda3/envs/patchgrid/lib/python3.9/site-packages/torch/include/THC -I/usr/local/cuda/include -I/ghome/l3/gylin/anaconda3/envs/patchgrid/include/python3.9 -c
post_cflags = -std=c++14 -ffast-math -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=mesh2sdf -D_GLIBCXX_USE_CXX11_ABI=0
cuda_cflags = -I/ghome/l3/gylin/anaconda3/envs/patchgrid/lib/python3.9/site-packages/torch/include -I/ghome/l3/gylin/anaconda3/envs/patchgrid/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/ghome/l3/gylin/anaconda3/envs/patchgrid/lib/python3.9/site-packages/torch/include/TH -I/ghome/l3/gylin/anaconda3/envs/patchgrid/lib/python3.9/site-packages/torch/include/THC -I/usr/local/cuda/include -I/ghome/l3/gylin/anaconda3/envs/patchgrid/include/python3.9 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -std=c++14 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=mesh2sdf -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags



build /ghome/l3/gylin/Patch-Grid-Final/metrics/lib/extensions/mesh2sdf_cuda/build/temp.linux-x86_64-3.9/mesh2sdf_kernel.o: cuda_compile /ghome/l3/gylin/Patch-Grid-Final/metrics/lib/extensions/mesh2sdf_cuda/mesh2sdf_kernel.cu





